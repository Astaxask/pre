{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PRE",
  "version": "0.1.0",
  "identifier": "com.astaxask.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PRE",
        "width": 420,
        "height": 720,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 480,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
