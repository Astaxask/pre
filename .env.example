# PRE — Personal Reality Engine
# Copy this file to .env and fill in your values.
# NEVER commit the .env file.

# Claude API — only used for cloud-safe tasks (optional)
ANTHROPIC_API_KEY=

# Plaid — financial data integration
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Google — Calendar + Gmail integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption — 32-byte hex key
# Generate with: openssl rand -hex 32
PRE_ENCRYPTION_KEY=

# Database path (optional, defaults to ~/.pre/pre.db)
PRE_DB_PATH=

# Redis connection (optional, defaults to localhost:6379)
REDIS_URL=redis://localhost:6379

# Gateway port (optional, defaults to 18789)
PRE_GATEWAY_PORT=18789

# Ollama endpoint (optional, defaults to http://localhost:11434)
OLLAMA_URL=http://localhost:11434